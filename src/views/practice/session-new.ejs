<%- include('../partials/header') %>

<a href="/practice/dashboard" class="back-link">&larr; Back to dashboard</a>

<h1>New Check-In</h1>

<% if (errors.length) { %>
    <ul class="form-errors">
        <% errors.forEach(function(error) { %><li><%= error.msg %></li><% }) %>
    </ul>
<% } %>

<% if (patients.length === 0) { %>
    <p>No patients have registered yet — a check-in session needs an existing patient account.</p>
<% } else if (forms.length === 0) { %>
    <p>No active forms yet. <a href="/practice/forms/new">Create one</a> first.</p>
<% } else { %>
    <form method="POST" action="/practice/sessions/new" class="auth-form">
        <label for="patientUserId">Patient</label>
        <select id="patientUserId" name="patientUserId" required>
            <option value="">Select a patient</option>
            <% patients.forEach(function(p) { %>
                <option value="<%= p.id %>"><%= p.first_name %> <%= p.last_name %> (<%= p.email %>)</option>
            <% }) %>
        </select>

        <% if (appointmentTypes.length > 0) { %>
            <label for="appointmentTypeFilter">Appointment Type</label>
            <select id="appointmentTypeFilter">
                <option value="">All forms</option>
                <% appointmentTypes.forEach(function(type) { %>
                    <option value="<%= type %>"><%= type %></option>
                <% }) %>
            </select>
            <p class="field-hint">Narrows the form list below to forms tagged for this appointment type.</p>
        <% } %>

        <label for="formId">Form</label>
        <select id="formId" name="formId" required>
            <option value="">Select a form</option>
            <% forms.forEach(function(f) { %>
                <option value="<%= f.id %>" data-appointment-type="<%= f.appointment_type || '' %>">
                    <%= f.title %><%= f.appointment_type ? ` (${f.appointment_type})` : '' %>
                </option>
            <% }) %>
        </select>

        <button type="submit">Create Check-In</button>
    </form>

    <script>
        const filterSelect = document.getElementById('appointmentTypeFilter');
        const formSelect = document.getElementById('formId');
        const allFormOptions = Array.from(formSelect.options);

        if (filterSelect) {
            filterSelect.addEventListener('change', () => {
                const chosenType = filterSelect.value;
                formSelect.innerHTML = '';
                allFormOptions.forEach((option) => {
                    const matches = !chosenType || option.value === '' || option.dataset.appointmentType === chosenType;
                    if (matches) formSelect.appendChild(option);
                });
            });
        }
    </script>
<% } %>

<%- include('../partials/footer') %>
