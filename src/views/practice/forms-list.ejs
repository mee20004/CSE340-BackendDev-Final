<%- include('../partials/header') %>

<a href="/practice/dashboard" class="back-link">&larr; Back to dashboard</a>

<h1>Forms</h1>

<% if (error) { %>
    <ul class="form-errors"><li><%= error %></li></ul>
<% } %>

<% if (currentUser.role === 'owner') { %>
    <p><a href="/practice/forms/new">+ New Form</a></p>
<% } %>

<% if (forms.length === 0) { %>
    <p>No forms yet.</p>
<% } else { %>
    <table class="data-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Appointment Type</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            <% forms.forEach(function(f) { %>
                <tr>
                    <td><%= f.title %></td>
                    <td><%= f.appointment_type || 'General' %></td>
                    <td><%= f.is_active ? 'Active' : 'Inactive' %></td>
                    <td>
                        <% if (currentUser.role === 'owner') { %>
                            <a href="/practice/forms/<%= f.id %>/edit">Edit</a>
                            <form method="POST" action="/practice/forms/<%= f.id %>/delete" class="inline-form" onsubmit="return confirm('Delete this form?');">
                                <button type="submit">Delete</button>
                            </form>
                        <% } %>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
<% } %>

<%- include('../partials/footer') %>
