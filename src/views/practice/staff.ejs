<%- include('../partials/header') %>

<a href="/practice/dashboard" class="back-link">&larr; Back to dashboard</a>

<h1>Manage Staff</h1>

<% if (errors.length) { %>
    <ul class="form-errors">
        <% errors.forEach(function(error) { %><li><%= error.msg %></li><% }) %>
    </ul>
<% } %>

<h2>Current Staff</h2>
<% if (staff.length === 0) { %>
    <p>No staff accounts yet.</p>
<% } else { %>
    <table class="data-table">
        <thead><tr><th>Name</th><th>Email</th><th></th></tr></thead>
        <tbody>
            <% staff.forEach(function(s) { %>
                <tr>
                    <td><%= s.first_name %> <%= s.last_name %></td>
                    <td><%= s.email %></td>
                    <td>
                        <form method="POST" action="/practice/staff/<%= s.id %>/delete" class="inline-form" onsubmit="return confirm('Remove this staff account?');">
                            <button type="submit">Remove</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
<% } %>

<h2>Add Staff Account</h2>
<form method="POST" action="/practice/staff" class="auth-form">
    <label for="firstName">First Name</label>
    <input type="text" id="firstName" name="firstName" value="<%= old.firstName || '' %>" required>

    <label for="lastName">Last Name</label>
    <input type="text" id="lastName" name="lastName" value="<%= old.lastName || '' %>" required>

    <label for="email">Email</label>
    <input type="email" id="email" name="email" value="<%= old.email || '' %>" required>

    <label for="phone">Phone (optional)</label>
    <input type="tel" id="phone" name="phone" value="<%= old.phone || '' %>">

    <label for="password">Temporary Password</label>
    <input type="password" id="password" name="password" minlength="8" required>

    <button type="submit">Create Staff Account</button>
</form>

<%- include('../partials/footer') %>
